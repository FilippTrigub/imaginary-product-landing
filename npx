#!/bin/bash
# Wrapper script for xing5/mcp-google-sheets
# Generates credentials file from environment variables and launches the MCP server

set -e

# Check required environment variables
if [ -z "$GOOGLE_CLIENT_ID" ] || [ -z "$GOOGLE_CLIENT_SECRET" ] || [ -z "$GOOGLE_OAUTH_REFRESH_TOKEN" ]; then
    echo "Error: Missing required environment variables" >&2
    echo "Required: GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GOOGLE_OAUTH_REFRESH_TOKEN" >&2
    exit 1
fi

# Create credentials directory
CREDENTIALS_DIR="/tmp/google-sheets-mcp"
mkdir -p "$CREDENTIALS_DIR"

# Generate credentials file
CREDENTIALS_PATH="$CREDENTIALS_DIR/credentials.json"

cat > "$CREDENTIALS_PATH" <<EOF
{
  "type": "authorized_user",
  "client_id": "$GOOGLE_CLIENT_ID",
  "client_secret": "$GOOGLE_CLIENT_SECRET",
  "refresh_token": "$GOOGLE_OAUTH_REFRESH_TOKEN"
}
EOF

# Export credentials path for the MCP server
export CREDENTIALS_PATH="$CREDENTIALS_PATH"

# Launch the actual MCP server
exec uvx mcp-google-sheets
